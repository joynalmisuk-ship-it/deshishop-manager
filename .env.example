# Production Server Configuration (cPanel / Live Server)
NODE_ENV=production

# Security: JWT Secret for token signing
# Generate with: openssl rand -base64 32
# Must be at least 32 characters for security
JWT_SECRET=your-very-long-secret-key-change-this-on-production

# Server Port
# Leave as 3000 or use whatever port cPanel assigns
PORT=3000

# Base path if app is served from a subpath (e.g., /app)
# Set to "/" if serving from root domain
APP_BASE=/app

# Gemini API Key (optional, for AI features)
# Get from: https://ai.google.dev/
GEMINI_API_KEY=

# Database and Storage (auto-created, no need to set)
# shop.db - SQLite database
# uploads/ - User uploads (logos, files)
# backups/ - Database backups

# Development Only (not needed on production server)
# DISABLE_HMR=true

